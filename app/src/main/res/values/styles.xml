<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TabItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="TabIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">@color/tab_text_color</item>
    </style>

    <style name="TabText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/tab_text_color</item>
    </style>

    <style name="Vp2TabTextStyle" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="AnimDemoBtnPrimary">
        <item name="android:layout_height">38dp</item>
        <item name="android:background">@drawable/bg_vp2_btn_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AnimDemoBtnSecondary">
        <item name="android:layout_height">38dp</item>
        <item name="android:background">@drawable/bg_vp2_btn_secondary</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/vp2_btn_secondary_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Vp2ModeChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:background">@drawable/bg_vp2_mode</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">18dp</item>
        <item name="android:textColor">@color/vp2_mode_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
