    <string name="customview_circle_progress">圆形进度条</string>
    <string name="customview_circle_progress_hint">Arc + 渐变 + 中心百分比</string>

    <string name="customview_circle_progress_title">圆形进度条</string>
    <string name="customview_circle_progress_desc">用 drawArc 画环形轨道，Paint 的 strokeCap = ROUND 让端点圆润；SweepGradient 给进度弧上色；中心 drawText 显示百分比。ValueAnimator 从 0 平滑动画到目标值。</string>
    <string name="customview_circle_progress_run">重新播放</string>
    <string name="customview_circle_progress_random">随机进度</string>

