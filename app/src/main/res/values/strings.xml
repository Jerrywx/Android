    <string name="customview_flow_hint">ViewGroup 测量 · 换行 · 边距</string>
    <string name="customview_flow_title">流式标签 FlowLayout</string>
    <string name="customview_flow_desc">自定义 ViewGroup：onMeasure 中把子 View 按水平方向排布，宽度不够就换行；onLayout 中按每行记录下的位置摆放。支持行间距 / 列间距，兼容 wrap_content 和 EXACTLY 模式。</string>
    <string name="customview_flow_add">添加标签</string>
    <string name="customview_flow_reset">重置</string>
    <string name="customview_flow_input_hint">输入新标签…</string>

    <string name="customview_drag_ball">可拖拽悬浮球</string>
    <string name="customview_drag_ball_hint">TouchSlop · Velocity · Scroller 贴边</string>
    <string name="customview_drag_ball_title">可拖拽悬浮球</string>
    <string name="customview_drag_ball_desc">ACTION_MOVE 中先用 TouchSlop 过滤微小抖动，超过阈值再判定为拖动；抬手时 VelocityTracker 拿到速度，Scroller 做惯性滑行；最后按停下时的横坐标吸附到最近的一条边。父容器边界约束避免飞出屏幕。</string>
    <string name="customview_drag_ball_center">回到中心</string>
    <string name="customview_drag_ball_text">拖我</string>

    <string name="customview_refresh">下拉刷新容器</string>
    <string name="customview_refresh_hint">拦截 · 头部动画 · 回弹</string>
    <string name="customview_refresh_title">下拉刷新容器</string>
    <string name="customview_refresh_desc">自定义 ViewGroup 包裹一个可滚动子 View：onInterceptTouchEvent 中在子 View 处于顶部且手指向下滑时拦截；ACTION_MOVE 里带阻尼下拉头部；抬手根据阈值决定回弹或触发刷新。刷新完成用 ValueAnimator 平滑收起头部。</string>
    <string name="customview_refresh_pull">下拉刷新</string>
    <string name="customview_refresh_release">松开刷新</string>
    <string name="customview_refresh_loading">正在刷新…</string>
    <string name="customview_refresh_done">刷新完成</string>

    <string name="customview_clear_edit">自定义 EditText</string>
    <string name="customview_clear_edit_hint">清除按钮 · 密码切换 · 自定义属性</string>
    <string name="customview_clear_edit_title">自定义 EditText</string>
    <string name="customview_clear_edit_desc">继承 AppCompatEditText：有内容时右侧显示清除图标，点击命中区域清空；密码模式额外支持眼睛图标切换明文/密文。通过 declare-styleable 自定义 app:showClearIcon、app:togglePassword 属性。</string>
    <string name="customview_clear_edit_normal_hint">带清除按钮</string>
    <string name="customview_clear_edit_password_hint">支持密码切换</string>

    <string name="customview_ripple">水波纹点击</string>
    <string name="customview_ripple_hint">多层圆环扩散 · Alpha 衰减</string>
    <string name="customview_ripple_title">水波纹点击</string>
    <string name="customview_ripple_desc">点击时在触点生成一圈波纹，用 ValueAnimator 同时驱动半径变大和透明度衰减。多次点击可叠加多个波纹，绘制时遍历活跃波纹分别 drawCircle。</string>
    <string name="customview_ripple_reset">清空波纹</string>

    <string name="customview_rating">星评分控件</string>
    <string name="customview_rating_hint">半星 · 拖动打分 · 动画填充</string>
    <string name="customview_rating_title">星评分控件</string>
    <string name="customview_rating_desc">用 Path 画出星形并缓存，绘制时先画空心背景，再用 clipRect 裁剪填充部分——支持半星精度。手指按下/拖动时根据 x 坐标换算成 rating，抬手用 ValueAnimator 平滑到目标值。</string>
    <string name="customview_rating_current">当前评分：%1$.1f</string>
    <string name="customview_rating_random">随机打分</string>

    <string name="customview_ruler">刻度尺 View</string>
    <string name="customview_ruler_hint">横向滚动 · 惯性 · 吸附</string>
    <string name="customview_ruler_title">刻度尺 View</string>
    <string name="customview_ruler_desc">横向刻度尺：VelocityTracker 拿到抬手速度，Scroller.fling 做惯性滑行；停下后吸附到最近整格。核心在 pixel ↔ value 的双向换算，中心线始终对齐当前值。</string>
    <string name="customview_ruler_current">当前身高：%1$d cm</string>
    <string name="customview_ruler_reset">回到 170</string>
    <string name="customview_ruler_random">随机身高</string>

    <string name="customview_wave">贝塞尔曲线波浪</string>
    <string name="customview_wave_hint">Path.quadTo · 双层叠加 · 横向滚动</string>
    <string name="customview_wave_title">贝塞尔曲线波浪</string>
    <string name="customview_wave_desc">用 Path.quadTo 拼接波峰和波谷，一段二阶贝塞尔就是半个波长。ValueAnimator 无限循环驱动横向位移，前后两层相位错开，颜色半透明叠加形成层次感。SeekBar 控制水位（波浪静止基线）。</string>
    <string name="customview_wave_random">随机水位</string>

    <string name="customview_dashboard">仪表盘</string>
    <string name="customview_dashboard_hint">270° 弧 · 刻度 · 指针 · 渐变</string>
    <string name="customview_dashboard_title">仪表盘</string>
    <string name="customview_dashboard_desc">起始角 135°、扫过 270° 的弧形轨道；SweepGradient 分三段绿-黄-红渲染进度。沿弧用 sin/cos 计算主/次刻度端点与数字位置；指针从中心向外画一条线，末端配一个圆头。ValueAnimator 平滑到目标值。</string>
    <string name="customview_dashboard_random">随机速度</string>
    <string name="customview_dashboard_zero">归零</string>

    <string name="customview_sticky">粘性水滴</string>
    <string name="customview_sticky_hint">两圆连接 · 拉伸 · 断裂 · 回弹</string>
    <string name="customview_sticky_title">粘性水滴</string>
    <string name="customview_sticky_desc">两个圆之间用两条对称的二阶贝塞尔连出"腰身"，控制点取两圆心中点。拖动距离越大，固定圆半径线性收缩，模拟被拉细；超过阈值判定断裂，此后只画拖拽圆。未断裂时抬手用 OvershootInterpolator 弹回原位。</string>
    <string name="customview_sticky_reset">重置</string>
    <string name="customview_sticky_burst">拖走了 · 红点已清</string>
</resources>
