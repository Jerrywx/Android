<?xml version="1.0" encoding="utf-8"?>
<!-- 帧动画：依次切换 6 帧不同颜色的圆点，循环播放 -->
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    <item android:drawable="@drawable/frame_dot_1" android:duration="120" />
    <item android:drawable="@drawable/frame_dot_2" android:duration="120" />
    <item android:drawable="@drawable/frame_dot_3" android:duration="120" />
    <item android:drawable="@drawable/frame_dot_4" android:duration="120" />
    <item android:drawable="@drawable/frame_dot_5" android:duration="120" />
    <item android:drawable="@drawable/frame_dot_6" android:duration="120" />
</animation-list>
