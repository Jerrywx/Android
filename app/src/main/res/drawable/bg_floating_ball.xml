<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#33000000" />
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    <!-- 主体蓝色圆 -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#1E88E5" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
</layer-list>
