<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_demo_index_card"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_note_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/demo_title"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_note_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/demo_subtitle"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/btn_note_edit"
            style="@style/AnimDemoBtnSecondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="@string/storage_note_edit" />
        <TextView
            android:id="@+id/btn_note_del"
            style="@style/AnimDemoBtnSecondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/storage_note_delete" />
    </LinearLayout>
</LinearLayout>
