<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/frame_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎞 帧动画 (Frame Animation)"
                    android:textColor="@color/demo_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="AnimationDrawable 通过逐帧切换 Drawable 来实现动画。适合 Loading、表情、icon 动画等场景。注意：必须在 onWindowFocusChanged 或延迟启动。"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Loading 动画 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔄 加载圆点"
                    android:textColor="@color/demo_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_loading"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:src="@drawable/frame_loading" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_start"
                        style="@style/AnimDemoBtnPrimary"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="开始" />

                    <TextView
                        android:id="@+id/btn_stop"
                        style="@style/AnimDemoBtnSecondary"
                        android:layout_width="0dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="停止" />
                </LinearLayout>
            </LinearLayout>

            <!-- 代码示例 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 核心代码"
                    android:textColor="@color/demo_title"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_search_field"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:padding="10dp"
                    android:text="// res/drawable/frame_loading.xml\n&lt;animation-list&gt;\n  &lt;item android:drawable=&apos;@drawable/d1&apos;\n        android:duration=&apos;100&apos;/&gt;\n  ...\n&lt;/animation-list&gt;\n\n// Kotlin\nval drawable = iv.drawable as AnimationDrawable\ndrawable.start()"
                    android:textColor="@color/demo_title"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
