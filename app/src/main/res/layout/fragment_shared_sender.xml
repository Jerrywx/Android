<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp">

    <EditText
        android:id="@+id/et_shared_input"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:layout_weight="1"
        android:background="@drawable/bg_vp2_input"
        android:hint="@string/frag_shared_input_hint"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textColor="@color/demo_title"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/btn_shared_send"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_vp2_btn_primary"
        android:gravity="center"
        android:paddingHorizontal="18dp"
        android:text="@string/frag_common_send"
        android:textColor="@color/vp2_btn_primary_text"
        android:textSize="13sp" />
</LinearLayout>
