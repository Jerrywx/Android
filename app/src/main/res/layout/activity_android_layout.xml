<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/android_layout_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/demo_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/header_bg"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <ImageButton
                android:id="@+id/demo_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/chat_back"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/demo_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:textColor="@color/header_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== LinearLayout 示例 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_demo_index_icon"
                    android:gravity="center"
                    android:text="L"
                    android:textColor="@color/demo_accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LinearLayout"
                        android:textColor="@color/demo_title"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="线性布局 · orientation 控制水平/垂直排列 · weight 按比例分配空间"
                        android:textColor="@color/demo_subtitle"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- LinearLayout 实战 Demo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 水平排列 + weight 权重"
                    android:textColor="@color/demo_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="搜索栏典型布局：TextView + EditText + Button 水平均分"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_rv_tag"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="搜索"
                        android:textColor="@color/demo_title"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="8dp"
                        android:background="@drawable/bg_search_field" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_vp2_btn_primary"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:text="确定"
                        android:textColor="@color/white"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="14dp"
                    android:background="@color/demo_divider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 垂直排列基础"
                    android:textColor="@color/demo_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="垂直方向依次排列，最常用的布局基础"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_rv_banner_1"
                        android:gravity="center"
                        android:text="第一行"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_rv_banner_2"
                        android:gravity="center"
                        android:text="第二行"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_rv_banner_3"
                        android:gravity="center"
                        android:text="第三行（依次垂直排列）"
                        android:textColor="@color/white"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== RelativeLayout 示例 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_demo_index_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_demo_index_icon"
                    android:gravity="center"
                    android:text="R"
                    android:textColor="@color/demo_accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RelativeLayout"
                        android:textColor="@color/demo_title"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="相对布局 · 子 View 之间或相对于父容器定位 · 适合复杂重叠关系"
                        android:textColor="@color/demo_subtitle"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- RelativeLayout 实战 Demo -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="148dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_demo_index_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 左上角标题 + 右下角按钮（相对定位）"
                    android:textColor="@color/demo_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_pro_card"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/rel_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="用户头像和名称"
                        android:textColor="@color/demo_title"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/rel_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_rv_tag"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:text="VIP"
                        android:textColor="@color/demo_accent"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignStart="@id/rel_title"
                        android:layout_below="@id/rel_title"
                        android:layout_marginTop="4dp"
                        android:text="在线 · 上海"
                        android:textColor="@color/demo_hint"
                        android:textSize="11sp" />
                </RelativeLayout>
            </FrameLayout>

            <!-- ===== FrameLayout 示例 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_demo_index_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_demo_index_icon"
                    android:gravity="center"
                    android:text="F"
                    android:textColor="@color/demo_accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="FrameLayout"
                        android:textColor="@color/demo_title"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="帧布局 · 所有子 View 堆叠在左上角 · 常用于 Fragment 容器/悬浮层"
                        android:textColor="@color/demo_subtitle"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- FrameLayout 实战 Demo -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_demo_index_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 图片占位 + 遮罩 + 文字叠加（层叠效果）"
                    android:textColor="@color/demo_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_rv_banner_4"
                    android:gravity="center">

                    <!-- 遮罩层 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#55000000" />

                    <!-- 播放按钮（居中） -->
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_vp2_btn_primary"
                        android:contentDescription="播放"
                        android:gravity="center"
                        android:text="▶"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <!-- 视频时长（右下角） -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:text="12:34"
                        android:textColor="@color/white"
                        android:textSize="11sp" />

                    <!-- 标题（左下角） -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="8dp"
                        android:text="视频标题"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </FrameLayout>

            <!-- ===== ConstraintLayout 示例 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_demo_index_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_demo_index_icon"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="@color/demo_accent"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ConstraintLayout"
                        android:textColor="@color/demo_title"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="约束布局 · 扁平化层级 · 强大的相对定位与链式约束 · 现代 Android 首选"
                        android:textColor="@color/demo_subtitle"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ConstraintLayout 实战 Demo -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="172dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_demo_index_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 扁平化复杂布局（模拟个人资料卡片）"
                    android:textColor="@color/demo_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_pro_card"
                    android:padding="14dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- 头像 -->
                        <TextView
                            android:id="@+id/constraint_avatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_rv_avatar"
                            android:gravity="center"
                            android:text="J"
                            android:textColor="@color/rv_avatar_text"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- 名称 -->
                        <TextView
                            android:id="@+id/constraint_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="John Doe"
                            android:textColor="@color/demo_title"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/constraint_bio"
                            app:layout_constraintEnd_toStartOf="@+id/constraint_follow"
                            app:layout_constraintStart_toEndOf="@+id/constraint_avatar"
                            app:layout_constraintTop_toTopOf="@+id/constraint_avatar"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <!-- 简介 -->
                        <TextView
                            android:id="@+id/constraint_bio"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Android 开发者 · 热爱 Kotlin"
                            android:textColor="@color/demo_subtitle"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="@+id/constraint_avatar"
                            app:layout_constraintEnd_toEndOf="@+id/constraint_name"
                            app:layout_constraintStart_toEndOf="@+id/constraint_avatar"
                            app:layout_constraintTop_toBottomOf="@+id/constraint_name" />

                        <!-- 关注按钮 -->
                        <TextView
                            android:id="@+id/constraint_follow"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_vp2_btn_primary"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="+ 关注"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- ===== wrap_content vs match_parent 示例 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_demo_index_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_demo_index_icon"
                    android:gravity="center"
                    android:text="📐"
                    android:textColor="@color/demo_accent"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="尺寸模式"
                        android:textColor="@color/demo_title"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="match_parent 填满父容器 · wrap_content 包裹内容 · dp/sp 固定尺寸"
                        android:textColor="@color/demo_subtitle"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 尺寸对比 Demo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 match_parent vs wrap_content 对比"
                    android:textColor="@color/demo_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <!-- wrap_content -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_rv_banner_1"
                        android:gravity="center"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="wrap_content（仅包裹内容）"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- match_parent -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_rv_banner_2"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="match_parent（填满父容器）"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- 固定 dp -->
                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_rv_banner_3"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200dp（固定宽度）"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="💡 提示：嵌套过多会影响性能，尽量使用 ConstraintLayout 扁平化层级"
                    android:textColor="@color/demo_hint"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
