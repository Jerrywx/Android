<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_lifecycle_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_demo_index_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/frag_life_desc"
            android:textColor="@color/demo_subtitle"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_lifecycle_add"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_vp2_btn_primary"
                android:gravity="center"
                android:text="@string/frag_life_action_add"
                android:textColor="@color/vp2_btn_primary_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_lifecycle_remove"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_vp2_btn_secondary"
                android:gravity="center"
                android:text="@string/frag_life_action_remove"
                android:textColor="@color/vp2_btn_secondary_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btn_lifecycle_clear"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_vp2_btn_secondary"
                android:gravity="center"
                android:text="@string/frag_common_clear"
                android:textColor="@color/vp2_btn_secondary_text"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragment_lifecycle_container"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_demo_index_card" />

    <ScrollView
        android:id="@+id/fragment_lifecycle_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_demo_index_card"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_lifecycle_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/frag_life_placeholder"
            android:textColor="@color/demo_title"
            android:textSize="12sp" />
    </ScrollView>
</LinearLayout>
