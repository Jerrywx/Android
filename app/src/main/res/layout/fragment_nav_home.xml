<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_demo_index_card"
        android:orientation="vertical"
        android:padding="16dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/jp_nav_home_title"
            android:textColor="@color/demo_title"
            android:textSize="17sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/jp_nav_home_desc"
            android:textColor="@color/demo_subtitle"
            android:textSize="13sp" />
        <EditText
            android:id="@+id/et_nav_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints="username"
            android:background="@drawable/bg_vp2_input"
            android:hint="@string/jp_nav_input_hint"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="@color/demo_title"
            android:textColorHint="@color/demo_subtitle"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/btn_nav_go"
            style="@style/AnimDemoBtnPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/jp_nav_go" />
    </LinearLayout>
</LinearLayout>
