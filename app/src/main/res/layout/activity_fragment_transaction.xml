<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fragment_tx_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:padding="14dp"
                android:text="@string/frag_tx_desc"
                android:textColor="@color/demo_subtitle"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="核心事务操作"
                android:textColor="@color/demo_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- 第一排：add / replace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_tx_add_a"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_primary"
                    android:gravity="center"
                    android:text="add A"
                    android:textColor="@color/vp2_btn_primary_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_tx_add_b"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_primary"
                    android:gravity="center"
                    android:text="add B"
                    android:textColor="@color/vp2_btn_primary_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_tx_replace_c"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_primary"
                    android:gravity="center"
                    android:text="replace C"
                    android:textColor="@color/vp2_btn_primary_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 第二排：hide / show / detach / attach -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_tx_hide"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_secondary"
                    android:gravity="center"
                    android:text="@string/frag_common_hide"
                    android:textColor="@color/vp2_btn_secondary_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_tx_show"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_secondary"
                    android:gravity="center"
                    android:text="@string/frag_common_show"
                    android:textColor="@color/vp2_btn_secondary_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_tx_detach"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_secondary"
                    android:gravity="center"
                    android:text="@string/frag_common_detach"
                    android:textColor="@color/vp2_btn_secondary_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_tx_attach"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_secondary"
                    android:gravity="center"
                    android:text="@string/frag_common_attach"
                    android:textColor="@color/vp2_btn_secondary_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 第三排：pop / clear -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_tx_pop"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_secondary"
                    android:gravity="center"
                    android:text="@string/frag_common_back"
                    android:textColor="@color/vp2_btn_secondary_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_tx_clear"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_vp2_btn_secondary"
                    android:gravity="center"
                    android:text="@string/frag_common_clear"
                    android:textColor="@color/vp2_btn_secondary_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 容器 -->
            <FrameLayout
                android:id="@+id/fragment_tx_container"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card" />

            <!-- 实时状态信息 -->
            <TextView
                android:id="@+id/tv_tx_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:textColor="@color/demo_title"
                android:textSize="12sp" />

            <!-- 操作日志 -->
            <TextView
                android:id="@+id/tv_tx_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_demo_index_card"
                android:fontFamily="monospace"
                android:minHeight="180dp"
                android:padding="12dp"
                android:textColor="@color/demo_subtitle"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
