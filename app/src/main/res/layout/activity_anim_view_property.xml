<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/vpa_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⛓ ViewPropertyAnimator"
                    android:textColor="@color/demo_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="view.animate() 链式调用，是属性动画最简洁的写法。内部对多个属性合并 invalidate，效率比单独 ObjectAnimator 更高。"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card">

                <View
                    android:id="@+id/vpa_target"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_anim_box" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_chain_simple"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="链式·基础" />

                <TextView
                    android:id="@+id/btn_chain_combo"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="链式·组合" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_chain_flip"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="3D 翻转" />

                <TextView
                    android:id="@+id/btn_chain_jump"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="跳跃" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_chain_shake"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="抖动" />

                <TextView
                    android:id="@+id/btn_reset"
                    style="@style/AnimDemoBtnSecondary"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/anim_reset" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 核心代码"
                    android:textColor="@color/demo_title"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_search_field"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:padding="10dp"
                    android:text="view.animate()\n    .translationX(200f)\n    .rotation(360f)\n    .scaleX(1.5f).scaleY(1.5f)\n    .setDuration(800)\n    .setInterpolator(OvershootInterpolator())\n    .withEndAction { /* 回调 */ }\n    .start()"
                    android:textColor="@color/demo_title"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
