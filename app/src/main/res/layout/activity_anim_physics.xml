<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/physics_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🪀 物理动画 (Physics-based)"
                    android:textColor="@color/demo_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="基于真实物理规律的动画。SpringAnimation 模拟弹簧（带阻尼振荡）；FlingAnimation 模拟惯性甩动。需依赖 androidx.dynamicanimation。"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Spring -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌀 SpringAnimation"
                    android:textColor="@color/demo_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="拖动小球后松手，观察弹簧回弹效果"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="12sp" />

                <FrameLayout
                    android:id="@+id/spring_stage"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginTop="8dp">

                    <View
                        android:id="@+id/spring_ball"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:layout_gravity="center"
                        android:background="@drawable/shape_anim_ball" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_spring_low"
                        style="@style/AnimDemoBtnPrimary"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="低阻尼" />

                    <TextView
                        android:id="@+id/btn_spring_medium"
                        style="@style/AnimDemoBtnPrimary"
                        android:layout_width="0dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="中阻尼" />

                    <TextView
                        android:id="@+id/btn_spring_high"
                        style="@style/AnimDemoBtnPrimary"
                        android:layout_width="0dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="高阻尼" />
                </LinearLayout>
            </LinearLayout>

            <!-- Fling -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💨 FlingAnimation"
                    android:textColor="@color/demo_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="点击发射，模拟初速度甩出后摩擦减速"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="12sp" />

                <FrameLayout
                    android:id="@+id/fling_stage"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp">

                    <View
                        android:id="@+id/fling_box"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/shape_anim_box" />
                </FrameLayout>

                <TextView
                    android:id="@+id/btn_fling"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="match_parent"
                    android:text="发射 (Fling)" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
