<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/interp_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📈 插值器 (Interpolator)"
                    android:textColor="@color/demo_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Interpolator 决定动画的进度曲线（缓动函数）。Android 内置 11 种插值器，覆盖加速、减速、弹簧、回弹、过冲等效果。点击任意按钮，观察同一段动画在不同插值器下的差异。"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card">

                <View
                    android:id="@+id/interp_target"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/shape_anim_ball" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_current"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="当前：—"
                android:textColor="@color/demo_accent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_linear"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Linear" />

                <TextView
                    android:id="@+id/btn_accelerate"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Accelerate" />

                <TextView
                    android:id="@+id/btn_decelerate"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Decelerate" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_ad"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="A·Decelerate" />

                <TextView
                    android:id="@+id/btn_overshoot"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Overshoot" />

                <TextView
                    android:id="@+id/btn_anticipate"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="Anticipate" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_bounce"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Bounce" />

                <TextView
                    android:id="@+id/btn_aod"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="A·Overshoot" />

                <TextView
                    android:id="@+id/btn_path"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="PathInterp" />
            </LinearLayout>

            <!-- TypeEvaluator 演示 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🧮 TypeEvaluator 自定义求值器"
                    android:textColor="@color/demo_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="自定义 Point 坐标在两点之间走抛物线"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="12sp" />

                <FrameLayout
                    android:id="@+id/parabola_stage"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp">

                    <View
                        android:id="@+id/parabola_target"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/shape_anim_ball" />
                </FrameLayout>

                <TextView
                    android:id="@+id/btn_parabola"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="match_parent"
                    android:layout_marginTop="8dp"
                    android:text="发射抛物线" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
