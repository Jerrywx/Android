<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/trans_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔀 过渡动画 (Transition)"
                    android:textColor="@color/demo_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="TransitionManager.beginDelayedTransition() 自动捕获布局变化前后的差异，并以动画方式补间。常用 Transition：Fade / ChangeBounds / Slide / AutoTransition。"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/trans_scene_root"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card">

                <LinearLayout
                    android:id="@+id/trans_card"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_anim_box"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/trans_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Card"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_change_bounds"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="ChangeBounds" />

                <TextView
                    android:id="@+id/btn_fade"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Fade" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_slide"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Slide" />

                <TextView
                    android:id="@+id/btn_auto"
                    style="@style/AnimDemoBtnPrimary"
                    android:layout_width="0dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="AutoTransition" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_explode"
                style="@style/AnimDemoBtnSecondary"
                android:layout_width="match_parent"
                android:layout_marginTop="8dp"
                android:text="@string/anim_reset" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 核心代码"
                    android:textColor="@color/demo_title"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_search_field"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:padding="10dp"
                    android:text="TransitionManager.beginDelayedTransition(\n    sceneRoot, ChangeBounds()\n)\n// 修改任意子 View 的布局参数\nview.layoutParams = newParams"
                    android:textColor="@color/demo_title"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
