<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/graphics_path_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/header_bg"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">
            <ImageButton
                android:id="@+id/demo_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/chat_back"
                android:src="@drawable/ic_back" />
            <TextView
                android:id="@+id/demo_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:textColor="@color/header_title"
                android:textSize="17sp"
                android:textStyle="bold" />
            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_demo_index_card"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/graphics_path_title"
                android:textColor="@color/demo_title"
                android:textSize="17sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/graphics_path_desc"
                android:textColor="@color/demo_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

        <com.example.appdemo.demo.graphics.widget.SignatureView
            android:id="@+id/signature_board"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_demo_index_card" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/btn_path_undo"
                style="@style/AnimDemoBtnSecondary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="@string/graphics_path_undo" />
            <TextView
                android:id="@+id/btn_path_clear"
                style="@style/AnimDemoBtnPrimary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/graphics_path_clear" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
