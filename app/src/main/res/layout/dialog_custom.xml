<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_demo_index_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/frag_dialog_title"
        android:textColor="@color/demo_title"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/frag_dialog_message"
        android:textColor="@color/demo_subtitle"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_common_cancel"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_dialog_confirm"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_primary"
            android:gravity="center"
            android:text="@string/frag_common_confirm"
            android:textColor="@color/vp2_btn_primary_text"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
