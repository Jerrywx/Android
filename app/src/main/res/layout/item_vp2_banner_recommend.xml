<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_vp2_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <FrameLayout
        android:id="@+id/vp2_banner_rec_cover"
        android:layout_width="60dp"
        android:layout_height="60dp">

        <TextView
            android:id="@+id/vp2_banner_rec_emoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="30sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/vp2_banner_rec_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/demo_title"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/vp2_banner_rec_sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/demo_subtitle"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/vp2_banner_rec_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/demo_hint"
        android:textSize="12sp" />
</LinearLayout>
