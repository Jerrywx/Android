<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/concat_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_demo_index_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <View
        android:id="@+id/concat_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_demo_index_icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/concat_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/demo_title"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/concat_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/demo_subtitle"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
