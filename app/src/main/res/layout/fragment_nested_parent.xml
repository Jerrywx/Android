<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tab_nested_a"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_nested_tab_a"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tab_nested_b"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_nested_tab_b"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tab_nested_c"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_nested_tab_c"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/container_child"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />
</LinearLayout>
