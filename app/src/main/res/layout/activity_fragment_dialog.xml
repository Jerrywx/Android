<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fragment_dialog_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:padding="14dp"
                android:text="@string/frag_dialog_desc"
                android:textColor="@color/demo_subtitle"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btn_dialog_custom"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_vp2_btn_primary"
                android:gravity="center"
                android:text="@string/frag_dialog_open"
                android:textColor="@color/vp2_btn_primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_dialog_alert"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_vp2_btn_secondary"
                android:gravity="center"
                android:text="@string/frag_dialog_open_alert"
                android:textColor="@color/vp2_btn_secondary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_dialog_full"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_vp2_btn_secondary"
                android:gravity="center"
                android:text="@string/frag_dialog_open_full"
                android:textColor="@color/vp2_btn_secondary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_dialog_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_demo_index_card"
                android:padding="14dp"
                android:text="@string/frag_result_none"
                android:textColor="@color/demo_title"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
