<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/study_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_demo_index_card"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/study_index"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_demo_index_icon"
        android:gravity="center"
        android:textColor="@color/demo_accent"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/study_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/demo_title"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/study_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/demo_subtitle"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="@color/demo_hint"
        android:textSize="22sp" />
</LinearLayout>
