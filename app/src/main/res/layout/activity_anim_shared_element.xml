<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/shared_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔗 共享元素动画"
                    android:textColor="@color/demo_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Activity 跳转时让两个页面之间的某个 View 平滑过渡。需要为前后页设置相同的 transitionName，并使用 ActivityOptions.makeSceneTransitionAnimation。"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="点击下方头像跳转"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/shared_avatar_1"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/shape_anim_circle"
                        android:transitionName="shared_avatar_1" />

                    <View
                        android:id="@+id/shared_avatar_2"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/shape_anim_star"
                        android:transitionName="shared_avatar_2" />

                    <View
                        android:id="@+id/shared_avatar_3"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@drawable/shape_anim_ball"
                        android:transitionName="shared_avatar_3" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 核心代码"
                    android:textColor="@color/demo_title"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_search_field"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:padding="10dp"
                    android:text="// 1. 两端 View 设置相同 transitionName\n// 2. 跳转时附加 ActivityOptions\nval opts = ActivityOptions\n  .makeSceneTransitionAnimation(\n    this, view, view.transitionName)\nstartActivity(intent, opts.toBundle())"
                    android:textColor="@color/demo_title"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
