<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_me_avatar">

        <View
            android:layout_width="42dp"
            android:layout_height="6dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_me_avatar_highlight" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/me_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/me_nickname"
            android:textColor="@color/me_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/me_wxid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/me_wxid"
            android:textColor="@color/me_subtitle"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/me_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:background="@drawable/bg_me_status_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_me_status_plus" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/me_status"
                    android:textColor="@color/me_title"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_me_status_ring" />
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/me_qr"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/me_qr_desc"
        android:src="@drawable/ic_me_qr" />
</LinearLayout>
