<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fragment_args_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_demo_index_card"
                android:padding="14dp"
                android:text="@string/frag_args_desc"
                android:textColor="@color/demo_subtitle"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_demo_index_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/frag_args_input_name"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_args_name"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_vp2_input"
                    android:hint="Alice"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/demo_title"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/frag_args_input_age"
                    android:textColor="@color/demo_subtitle"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_args_age"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_vp2_input"
                    android:hint="18"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/demo_title"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_args_create"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_vp2_btn_primary"
                        android:gravity="center"
                        android:text="@string/frag_args_create"
                        android:textColor="@color/vp2_btn_primary_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/btn_args_reset"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_vp2_btn_secondary"
                        android:gravity="center"
                        android:text="@string/frag_args_reset"
                        android:textColor="@color/vp2_btn_secondary_text"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/fragment_args_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="160dp"
                android:background="@drawable/bg_demo_index_card" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
