<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/demo_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vp2_wizard_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <LinearLayout
        android:id="@+id/vp2_wiz_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/vp2_wiz_step_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="4dp"
        android:textColor="@color/demo_hint"
        android:textSize="12sp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp2_wiz_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/vp2_wiz_prev"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/vp2_wizard_prev"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="12dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/vp2_wiz_next"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="2"
            android:background="@drawable/bg_vp2_btn_primary"
            android:gravity="center"
            android:text="@string/vp2_wizard_next"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
