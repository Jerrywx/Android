<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_vp2_card"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/vp2_tab_cover"
        android:layout_width="76dp"
        android:layout_height="76dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/vp2_tab_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/demo_title"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/vp2_tab_sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/demo_subtitle"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/vp2_tab_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_vp2_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/demo_accent"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/vp2_tab_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/demo_hint"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
