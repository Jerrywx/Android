<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fragment_container_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/demo_index_bg"
    android:orientation="vertical">

    <include layout="@layout/include_demo_toolbar" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_demo_index_card"
        android:padding="14dp"
        android:text="@string/frag_container_desc"
        android:textColor="@color/demo_subtitle"
        android:textSize="12sp" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_demo_index_card" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_demo_index_card"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/tab_container_home"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_container_tab_home"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tab_container_message"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_container_tab_message"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tab_container_profile"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_vp2_btn_secondary"
            android:gravity="center"
            android:text="@string/frag_container_tab_profile"
            android:textColor="@color/vp2_btn_secondary_text"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
